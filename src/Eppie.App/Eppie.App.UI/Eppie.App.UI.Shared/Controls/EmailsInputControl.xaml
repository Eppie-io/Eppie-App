<UserControl x:Class="Eppie.App.UI.Controls.EmailsInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Eppie.App.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Eppie.App.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             xmlns:toolkitcontrols="using:CommunityToolkit.WinUI.Controls"
             xmlns:viewmodels="using:Tuvi.App.ViewModels"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/TokenizingTextBoxStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="SuggestContactItemTemplate" x:DataType="viewmodels:ContactItem">
                <Grid Padding="2" BorderThickness="1">
                    <controls:AddressPresenter HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               Address="{x:Bind Email.Address, Mode=OneWay}"
                                               Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                               DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                               IsAddressValid="{x:Bind Email, Converter={StaticResource EmailValidityToBoolConverter}}"
                                               IsSecure="{x:Bind Email.IsDecentralized, Mode=OneWay}" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="TokenContactItemTemplate" x:DataType="viewmodels:ContactItem">
                <Grid Height="32"
                      BorderThickness="1"
                      ToolTipService.ToolTip="{x:Bind Email.Address, Mode=OneWay}">
                    <controls:AddressPresenter Margin="2"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                               DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                               IsAddressValid="{x:Bind Email, Converter={StaticResource EmailValidityToBoolConverter}}"
                                               IsSecure="{x:Bind Email.IsDecentralized, Mode=OneWay}"
                                               Mode="Compact" />
                </Grid>
            </DataTemplate>

            <local:BoolToStyleSelectorConverter x:Key="StyleSelectorConverter"
                                                FalseValue="{StaticResource EmailTokenizingTextBoxStyleSelector}"
                                                TrueValue="{StaticResource EmailTokenizingTextBoxReservedSpaceStyleSelector}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <toolkitcontrols:TokenizingTextBox x:Name="EmailTokenizingTextBox"
                                           MinHeight="40"
                                           Padding="2,4,0,4"
                                           ItemContainerStyleSelector="{x:Bind IsExtraButtonVisible, Mode=OneWay, Converter={StaticResource StyleSelectorConverter}}"
                                           ItemsSource="{x:Bind SelectedContacts, Mode=OneWay}"
                                           LostFocus="SuggestBox_LostFocus"
                                           PlaceholderText="{x:Bind PlaceholderText, Mode=OneWay}"
                                           QuerySubmitted="SuggestBox_QuerySubmitted"
                                           SuggestedItemTemplate="{StaticResource SuggestContactItemTemplate}"
                                           SuggestionChosen="SuggestBox_SuggestionChosen"
                                           TextChanged="SuggestBox_TextChanged"
                                           TokenDelimiter=";"
                                           TokenItemAdded="SuggestBox_TokenItemAdded"
                                           TokenItemAdding="SuggestBox_TokenItemAdding"
                                           TokenItemTemplate="{StaticResource TokenContactItemTemplate}" />

        <!--  Extra button  -->
        <Button Width="28"
                Height="28"
                Margin="8,6"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Command="{x:Bind ExtraCommand, Mode=OneWay}"
                Content="{x:Bind ExtraButtonContent, Mode=OneWay}"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Style="{StaticResource TokenizingTextBoxQueryButtonStyle}"
                Visibility="{x:Bind IsExtraButtonVisible, Mode=OneWay}" />
    </Grid>
</UserControl>
