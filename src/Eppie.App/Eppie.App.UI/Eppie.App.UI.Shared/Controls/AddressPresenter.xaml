<UserControl x:Class="Eppie.App.UI.Controls.AddressPresenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Tuvi.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Eppie.App.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             xmlns:toolkit="using:CommunityToolkit.WinUI"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">
    <UserControl.Resources>
        <x:Double x:Key="AvatarSize">26</x:Double>
        <x:Double x:Key="SecureIconSize">10</x:Double>
        <Thickness x:Key="ColumnSpaceMargin">12,0,0,0</Thickness>
        <local:AddressPresenterMode x:Key="NormalMode">Normal</local:AddressPresenterMode>
        <local:AddressPresenterMode x:Key="CompactMode">Compact</local:AddressPresenterMode>
        <local:AddressPresenterMode x:Key="StructuredMode">Structured</local:AddressPresenterMode>
        <x:String x:Key="LockGlyph">&#xE72E;</x:String>
        <StaticResource x:Key="SecureGlyph" ResourceKey="LockGlyph" />

        <Style x:Key="ValidPrimaryTextBlockStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="ValidSecondaryTextBlockStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="InvalidTextBlockStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource SystemControlErrorTextForegroundBrush}" />
        </Style>

        <converters:BoolToStyleConverter x:Key="ValidityToPrimaryStyleConverter"
                                         FalseValue="{StaticResource InvalidTextBlockStyle}"
                                         TrueValue="{StaticResource ValidPrimaryTextBlockStyle}" />

        <converters:BoolToStyleConverter x:Key="ValidityToSecondaryStyleConverter"
                                         FalseValue="{StaticResource InvalidTextBlockStyle}"
                                         TrueValue="{StaticResource ValidSecondaryTextBlockStyle}" />

    </UserControl.Resources>

    <Grid x:Name="RootGrid" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="NameColumn"
                              Width="*"
                              MaxWidth="{x:Bind local:DataBinding.GetNameColumnMaxWidth(Mode, NameColumnMaxWidth), Mode=OneWay}" />
            <ColumnDefinition x:Name="AddressColumn" Width="*" />
        </Grid.ColumnDefinitions>

        <muxc:PersonPicture Width="{StaticResource AvatarSize}"
                            Height="{StaticResource AvatarSize}"
                            VerticalAlignment="Center"
                            DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                            ProfilePicture="{x:Bind Avatar, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}" />

        <Grid x:Name="NameGrid"
              Grid.Column="1"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DisplayNameTextBlock"
                       Margin="{StaticResource ColumnSpaceMargin}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Style="{x:Bind IsAddressValid, Mode=OneWay, Converter={StaticResource ValidityToPrimaryStyleConverter}}"
                       Text="{x:Bind DisplayName, Mode=OneWay}"
                       TextLineBounds="Tight"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" />

            <TextBlock x:Name="SecureTextBlock"
                       Grid.Column="1"
                       Margin="4,0,0,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                       FontSize="{StaticResource SecureIconSize}"
                       Style="{x:Bind IsAddressValid, Mode=OneWay, Converter={StaticResource ValidityToPrimaryStyleConverter}}"
                       Text="{StaticResource SecureGlyph}"
                       TextLineBounds="Tight"
                       Visibility="{x:Bind IsSecure, Mode=OneWay}" />
        </Grid>

        <TextBlock x:Name="AddressTextBlock"
                   Grid.Column="2"
                   Margin="{StaticResource ColumnSpaceMargin}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Style="{x:Bind IsAddressValid, Mode=OneWay, Converter={StaticResource ValidityToSecondaryStyleConverter}}"
                   Text="{x:Bind Address, Mode=OneWay}"
                   TextLineBounds="Tight"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal">
                    <VisualState.StateTriggers>
                        <toolkit:IsEqualStateTrigger Value="{x:Bind Mode, Mode=OneWay}" To="{StaticResource NormalMode}" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="Compact">
                    <VisualState.StateTriggers>
                        <toolkit:IsEqualStateTrigger Value="{x:Bind Mode, Mode=OneWay}" To="{StaticResource CompactMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AddressTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="AddressColumn.Width" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Structured">
                    <VisualState.StateTriggers>
                        <toolkit:IsEqualStateTrigger Value="{x:Bind Mode, Mode=OneWay}" To="{StaticResource StructuredMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NameColumn.Width" Value="100*" />
                        <Setter Target="RootGrid.HorizontalAlignment" Value="Stretch" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
