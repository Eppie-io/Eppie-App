<UserControl x:Class="Eppie.App.UI.Controls.WhatsNewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Eppie.App.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             MaxWidth="360"
             MaxHeight="480"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="WhatsNewSubtitleTextBlockStyle"
               BasedOn="{StaticResource SubtitleTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

    </UserControl.Resources>

    <Grid Padding="0,-8,4,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Share Button  -->
            <HyperlinkButton Grid.Column="0"
                             Margin="-4,0,0,0"
                             NavigateUri="{x:Bind TwitterUrl, Mode=OneTime}">
                <SymbolIcon Symbol="Share" />
            </HyperlinkButton>

            <!--  Title  -->
            <TextBlock x:Uid="/Eppie.App.UI/Controls/WhatsNew"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!--  Close Button  -->
            <AppBarButton Grid.Column="2"
                          Width="48"
                          Height="48"
                          Margin="0,0,-12,0"
                          VerticalAlignment="Top"
                          Click="CloseButton_Click">
                <SymbolIcon Symbol="Cancel" />
            </AppBarButton>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="12,12,-23,0"
                      Padding="0,0,23,0">
            <StackPanel Spacing="20">

                <!--  Version  -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                    <TextBlock x:Uid="/Eppie.App.UI/Controls/Version" />
                    <TextBlock Text="{x:Bind Version, Mode=OneWay}" />
                </StackPanel>

                <HyperlinkButton Height="150"
                                 HorizontalAlignment="Stretch"
                                 Content="Join the Testnet"
                                 FontSize="20"
                                 FontWeight="SemiBold"
                                 Foreground="Black"
                                 NavigateUri="https://eppie.io"
                                 Style="{StaticResource BrandGradientButtonBaseStyle}" />

                <!--  News 1 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Try decentralized addresses" />
                    <TextBlock Text="With Eppie Preview, you can already use decentralized Eppie and Bitcoin addresses for communication on Testnet. This feature will roll out to all versions after testing." TextWrapping="Wrap" />
                    <HyperlinkButton Margin="-12,0,0,0"
                                     HorizontalAlignment="Left"
                                     NavigateUri="https://github.com/Eppie-io/Eppie-App/releases/tag/v1.2.0-preview">
                        <HyperlinkButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" />
                                <TextBlock Text="Download Preview" />
                            </StackPanel>
                        </HyperlinkButton.Content>
                    </HyperlinkButton>
                </StackPanel>

                <!--  News 2 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Connection &amp; security improvements" />
                    <TextBlock Text="The Proton Mail connection flow is now simpler and more reliable. We’ve also added new protections for external content and embedded web resources to keep your communication safer." TextWrapping="Wrap" />
                </StackPanel>

                <!--  News 3 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Smoother experience across the app" />
                    <TextBlock Text="Layout and sorting preferences are now saved between sessions, and folder management is more intuitive. The UI has also been polished with new Contacts and Mailboxes panels, redesigned message tiles, and a better Compose experience." TextWrapping="Wrap" />
                </StackPanel>

                <local:SupportDevelopmentControl Margin="0"
                                                 HorizontalAlignment="Left"
                                                 IsIconVisible="False"
                                                 IsStorePaymentProcessor="{x:Bind IsStorePaymentProcessor, Mode=OneWay}"
                                                 Price="{x:Bind Price, Mode=OneWay}"
                                                 SupportDevelopmentCommand="{x:Bind SupportDevelopmentCommand}"
                                                 Visibility="{x:Bind IsSupportDevelopmentButtonVisible, Mode=OneWay}" />

                <!--  Old Version  -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                    <TextBlock x:Uid="/Eppie.App.UI/Controls/Version" />
                    <TextBlock Text="1.0.185.0" />
                </StackPanel>

                <!--  Old News  -->

                <!--  News 1 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Eppie is now on Snap Store" />
                    <TextBlock Text="The full functionality app is now available for Linux users through Snap. You can install it with a single command on any Snap-enabled system. Other packages and app stores will be available soon." TextWrapping="Wrap" />
                    <HyperlinkButton Margin="-12,0,0,0"
                                     HorizontalAlignment="Left"
                                     NavigateUri="https://snapcraft.io/eppie">
                        <HyperlinkButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" />
                                <TextBlock Text="Open Snap Store" />
                            </StackPanel>
                        </HyperlinkButton.Content>
                    </HyperlinkButton>
                </StackPanel>

                <!--  News 2 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Le français est arrivé" />
                    <TextBlock Text="Thanks to our community, French is now available. Feel free to switch to it anytime in Settings. If you spot a mistake or want to help translate Eppie into your language, follow the link below." TextWrapping="Wrap" />
                    <HyperlinkButton Margin="-12,0,0,0"
                                     HorizontalAlignment="Left"
                                     NavigateUri="https://eppie.crowdin.com/eppie">
                        <HyperlinkButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" />
                                <TextBlock Text="Open Crowdin" />
                            </StackPanel>
                        </HyperlinkButton.Content>
                    </HyperlinkButton>
                </StackPanel>

                <!--  News 3 is in English only for now  -->
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource WhatsNewSubtitleTextBlockStyle}" Text="Settings got a fresh new look" />
                    <TextBlock Text="We’ve redesigned and reorganized the settings to make them clearer and easier to navigate. You’ll also find new options in address settings and main app preferences." TextWrapping="Wrap" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
