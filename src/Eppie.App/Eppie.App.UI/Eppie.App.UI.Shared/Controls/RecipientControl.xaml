<UserControl x:Class="Eppie.App.UI.Controls.RecipientControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="using:Eppie.App.UI.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
             xmlns:local="using:Eppie.App.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <UserControl.Resources>
        <CornerRadius x:Key="RecipientControlCornerRadius">16</CornerRadius>
        <Thickness x:Key="RecipientControlPadding">2,2,12,2</Thickness>
        <Thickness x:Key="RecipientControlBorderThickness">1</Thickness>
        <x:Double x:Key="RecipientControlFlyoutMaxWidth">500</x:Double>

        <DataTemplate x:Key="RecipientTemplate" x:DataType="local:IRecipientItem">
            <local:AddressPresenter HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Address="{x:Bind Address, Mode=OneWay}"
                                    Avatar="{x:Bind Avatar, Mode=OneWay}"
                                    DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                    IsAvatarHighlighted="{x:Bind IsSecure, Mode=OneWay}"
                                    IsSecure="{x:Bind IsSecure, Mode=OneWay}">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddressPresenterTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </local:AddressPresenter>
        </DataTemplate>

    </UserControl.Resources>

    <Button Padding="{StaticResource RecipientControlPadding}"
            BorderBrush="{x:Bind BorderBrush, Mode=OneWay}"
            BorderThickness="{StaticResource RecipientControlBorderThickness}"
            CornerRadius="{StaticResource RecipientControlCornerRadius}"
            Style="{StaticResource ThinButtonStyle}">
        <Grid Margin="0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <local:AddressPresenter Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Address="{x:Bind local:RecipientControl.GetPrimaryRecepientAddress(PrimaryRecepient, ItemsSource), Mode=OneWay}"
                                    Avatar="{x:Bind local:RecipientControl.GetPrimaryRecepientAvatar(PrimaryRecepient, ItemsSource), Mode=OneWay}"
                                    DisplayName="{x:Bind local:RecipientControl.GetPrimaryRecepientName(PrimaryRecepient, ItemsSource), Mode=OneWay}"
                                    IsAvatarHighlighted="{x:Bind local:RecipientControl.IsPrimaryRecepientSecure(PrimaryRecepient, ItemsSource), Mode=OneWay}"
                                    IsSecure="{x:Bind local:RecipientControl.IsPrimaryRecepientSecure(PrimaryRecepient, ItemsSource), Mode=OneWay}"
                                    Mode="Compact">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddressPresenterTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </local:AddressPresenter>
            <TextBlock Grid.Column="1"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       TextLineBounds="Tight"
                       Visibility="{x:Bind local:RecipientControl.GetAdditionalRecipientVisibility(ItemsSource), Mode=OneWay}">
                <Run Text="+" /><Run Text="{x:Bind local:RecipientControl.GetAdditionalRecipientCount(ItemsSource), Mode=OneWay}" />
            </TextBlock>
        </Grid>
        <Button.Flyout>
            <!--
                ToDo: Replace this Flyout with a popup similar to the one used in ComboBox.
            -->
            <Flyout>
                <Flyout.FlyoutPresenterStyle>
                    <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                        <Setter Property="ScrollViewer.ZoomMode" Value="Disabled" />
                        <Setter Property="MaxWidth" Value="{StaticResource RecipientControlFlyoutMaxWidth}" />
                    </Style>
                </Flyout.FlyoutPresenterStyle>
                <ListView HorizontalAlignment="Stretch"
                          IsItemClickEnabled="False"
                          ItemTemplate="{StaticResource RecipientTemplate}"
                          ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                          SelectionMode="None" />
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
