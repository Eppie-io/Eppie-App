<UserControl x:Class="Eppie.App.UI.Controls.AttachmentFileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Eppie.App.UI.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="SymbolButtonSize">32</x:Double>
        <x:Double x:Key="FileSymbolSize">20</x:Double>
        <x:Double x:Key="FileThumbnailSize">48</x:Double>
        <x:Double x:Key="AttachmentItemWidth">282</x:Double>

        <Style x:Key="AdditionalTextBlockStyle"
               BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <MenuFlyout x:Key="CommandMenu">
            <MenuFlyoutItem x:Uid="/Eppie.App.UI/Controls/SaveAttachedFileMenuItem"
                            Command="{x:Bind SaveFileCommand}"
                            CommandParameter="{x:Bind SaveFileCommandParameter}"
                            Icon="Save"
                            IsEnabled="{x:Bind IsFileEmpty, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            Visibility="{x:Bind SaveFileCommand, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}" />
            <MenuFlyoutItem x:Uid="/Eppie.App.UI/Controls/OpenAttachedFileMenuItem"
                            Command="{x:Bind OpenFileCommand}"
                            CommandParameter="{x:Bind OpenFileCommandParameter}"
                            Icon="OpenFile"
                            IsEnabled="{x:Bind IsFileEmpty, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            Visibility="{x:Bind OpenFileCommand, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}" />
            <MenuFlyoutItem x:Uid="/Eppie.App.UI/Controls/DeleteAttachedFileMenuItem"
                            Command="{x:Bind DeleteFileCommand, Mode=OneWay}"
                            CommandParameter="{x:Bind DeleteFileCommandParameter}"
                            Icon="Delete"
                            Visibility="{x:Bind DeleteFileCommand, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}" />
        </MenuFlyout>
    </UserControl.Resources>

    <local:ItemContainer ContextFlyout="{StaticResource CommandMenu}"
                         CornerRadius="{ThemeResource ControlCornerRadius}"
                         Invoked="OnInvoked">
        <Grid Width="{StaticResource AttachmentItemWidth}" Padding="4,4,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="{StaticResource FileThumbnailSize}"
                  Height="{StaticResource FileThumbnailSize}"
                  Background="{ThemeResource ControlSolidFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="{ThemeResource ControlCornerRadius}">

                <Viewbox Width="{StaticResource FileSymbolSize}"
                         Height="{StaticResource FileSymbolSize}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{x:Bind FileThumbnail, Mode=OneWay, Converter={StaticResource InverseObjectToVisibilityConverter}}">
                    <SymbolIcon Symbol="Document" />
                </Viewbox>

                <Image Width="{StaticResource FileThumbnailSize}"
                       Height="{StaticResource FileThumbnailSize}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Source="{x:Bind FileThumbnail, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                       Stretch="Uniform"
                       Visibility="{x:Bind FileThumbnail, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}" />
            </Grid>

            <Grid Grid.Column="1"
                  Margin="12,0"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.ColumnSpan="2"
                           Margin="0,0,0,4"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Text="{x:Bind FileName, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Style="{StaticResource AdditionalTextBlockStyle}"
                           Text="{x:Bind FileExtension, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Style="{StaticResource AdditionalTextBlockStyle}"
                           Text="{x:Bind FileSize, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Button Grid.RowSpan="2"
                    Grid.Column="5"
                    Width="{StaticResource SymbolButtonSize}"
                    Height="{StaticResource SymbolButtonSize}"
                    Padding="0"
                    VerticalAlignment="Center"
                    Flyout="{StaticResource CommandMenu}"
                    Style="{StaticResource ThinButtonStyle}">
                <SymbolIcon Symbol="More" />
            </Button>
        </Grid>
    </local:ItemContainer>
</UserControl>
