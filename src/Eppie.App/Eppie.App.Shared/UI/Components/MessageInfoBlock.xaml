<UserControl x:Class="Eppie.App.UI.Components.MessageInfoBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="using:Eppie.App.UI.Behaviors"
             xmlns:controls="using:Eppie.App.UI.Controls"
             xmlns:converters="using:Eppie.App.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
             xmlns:local="using:Eppie.App.UI.Components"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             xmlns:toolkit="using:CommunityToolkit.WinUI"
             xmlns:tuvi_converters="using:Tuvi.App.Converters"
             d:DesignHeight="300"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:MessageInfoBlockMode x:Key="NameAddressModeKey">NameAddress</local:MessageInfoBlockMode>
        <local:MessageInfoBlockMode x:Key="NameAddressSubjectModeKey">NameAddressSubject</local:MessageInfoBlockMode>

        <x:Double x:Key="AvatarSize">44</x:Double>
        <x:Double x:Key="AvatarBorderThickness">2</x:Double>
        <x:Double x:Key="RecipientMinWidth">84</x:Double>
        <x:Double x:Key="RecipientMaxWidth">232</x:Double>
        <x:Double x:Key="InfoMaxWidth">600</x:Double>

        <x:Double x:Key="NanoWidth">200</x:Double>
        <x:Double x:Key="MicroWidth">350</x:Double>
        <x:Double x:Key="MiniWidth">460</x:Double>
        <x:Double x:Key="CompactWidth">540</x:Double>
        <x:Double x:Key="NarrowWidth">700</x:Double>

        <x:String x:Key="LockGlyph">&#xE72E;</x:String>
        <StaticResource x:Key="SecurityGlyph" ResourceKey="LockGlyph" />

        <Style x:Key="TertiaryFontIconStyle"
               BasedOn="{StaticResource DefaultFontIconStyle}"
               TargetType="FontIcon">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        </Style>

        <Style x:Key="AvatarHighlightedStyle"
               BasedOn="{StaticResource DefaultPersonPictureStyle}"
               TargetType="muxc:PersonPicture">
            <Setter Property="BorderBrush" Value="{ThemeResource AvatarHighlightedBrush}" />
        </Style>

        <tuvi_converters:BoolToStyleConverter x:Key="BoolToAvatarStyleConverter"
                                              FalseValue="{StaticResource DefaultPersonPictureStyle}"
                                              TrueValue="{StaticResource AvatarHighlightedStyle}" />

        <tuvi_converters:BoolToStyleConverter x:Key="SecureStyleConverter"
                                              FalseValue="{StaticResource TertiaryFontIconStyle}"
                                              TrueValue="{StaticResource DefaultFontIconStyle}" />

        <converters:RecipientConverter x:Key="RecipientConverter" />
        <converters:ListRecipientsConverter x:Key="ListRecipientsConverter" />
    </UserControl.Resources>

    <Grid x:Name="ParentGrid"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <muxc:PersonPicture Width="{StaticResource AvatarSize}"
                            Height="{StaticResource AvatarSize}"
                            Margin="0,4,12,0"
                            VerticalAlignment="Bottom"
                            DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                            ProfilePicture="{x:Bind Avatar, Mode=OneWay}"
                            Style="{x:Bind IsDecentralized, Mode=OneWay, Converter={StaticResource BoolToAvatarStyleConverter}}">
            <muxc:PersonPicture.Resources>
                <StaticResource x:Key="PersonPictureEllipseStrokeThickness" ResourceKey="AvatarBorderThickness" />
            </muxc:PersonPicture.Resources>
        </muxc:PersonPicture>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition x:Name="InfoColumn"
                                  Width="2*"
                                  MaxWidth="{StaticResource InfoMaxWidth}" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="32" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:AddressPresenter x:Name="MessageSenderPresenter"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Address="{x:Bind Address, Mode=OneWay}"
                                       DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                       DisplayNameTextStyle="{x:Bind IsRead, Mode=OneWay, Converter={StaticResource InverseBoolToAccentTextBlockStyleConverter}}"
                                       IsAvatarHighlighted="{x:Bind IsDecentralized, Mode=OneWay}"
                                       IsAvatarVisible="False"
                                       IsSecure="{x:Bind IsDecentralized, Mode=OneWay}"
                                       IsTextSelectionEnabled="{x:Bind IsTextSelectionEnabled, Mode=OneWay}"
                                       Mode="Compact">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddressPresenterTooltipBehavior x:Name="MessageSenderTooltip" Mode="Name" />
                </interactivity:Interaction.Behaviors>
            </controls:AddressPresenter>

            <TextBlock x:Name="MessageAddressBlock"
                       Grid.Row="1"
                       Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       IsTextSelectionEnabled="{x:Bind IsTextSelectionEnabled, Mode=OneWay}"
                       Text="{x:Bind Address, Mode=OneWay}"
                       TextLineBounds="TrimToBaseline"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       Visibility="Visible">
                <interactivity:Interaction.Behaviors>
                    <behaviors:TextBlockTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </TextBlock>

            <TextBlock x:Name="MessageSubjectBlock"
                       Grid.Row="1"
                       Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       IsTextSelectionEnabled="{x:Bind IsTextSelectionEnabled, Mode=OneWay}"
                       Style="{x:Bind IsRead, Mode=OneWay, Converter={StaticResource InverseBoolToAccentTextBlockStyleConverter}}"
                       Text="{x:Bind Subject, Mode=OneWay}"
                       TextLineBounds="TrimToBaseline"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       Visibility="Collapsed">
                <interactivity:Interaction.Behaviors>
                    <behaviors:TextBlockTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </TextBlock>

            <Grid Grid.Column="1" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition x:Name="RecipientColumn"
                                      Width="*"
                                      MinWidth="{StaticResource RecipientMinWidth}"
                                      MaxWidth="{StaticResource RecipientMaxWidth}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Note: The Background="Transparent" property allows the tooltip to appear on the entire panel.  -->
                <StackPanel x:Name="AttachmentInfo"
                            x:Uid="MessageAttachmentInfo"
                            Grid.Column="0"
                            Margin="8,0,16,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            Orientation="Horizontal"
                            Spacing="4"
                            Visibility="{x:Bind HasAttachments, Mode=OneWay}">
                    <Viewbox Width="16"
                             Height="16"
                             VerticalAlignment="Center">
                        <SymbolIcon Symbol="Attach" />
                    </Viewbox>
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind AttachmentCount, Mode=OneWay}" />
                </StackPanel>


                <FontIcon x:Name="SecurityInfo"
                          Grid.Column="1"
                          Margin="8,0,16,0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          FontSize="16"
                          Glyph="{StaticResource SecurityGlyph}"
                          Style="{x:Bind IsSecure, Mode=OneWay, Converter={StaticResource SecureStyleConverter}}"
                          ToolTipService.ToolTip="{x:Bind SecureTooltip, Mode=OneWay}" />


                <TextBlock x:Name="RecipientLabel"
                           x:Uid="MessageTo"
                           Grid.Column="2"
                           Margin="8,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <controls:RecipientControl x:Name="RecipientControl"
                                           Grid.Column="3"
                                           Margin="8,0,0,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                           ItemsSource="{x:Bind Recipients, Mode=OneWay, Converter={StaticResource ListRecipientsConverter}}"
                                           PrimaryRecepient="{x:Bind PrimaryRecepient, Mode=OneWay, Converter={StaticResource RecipientConverter}}" />

                <StackPanel x:Name="DateTimeInfo"
                            Grid.Column="4"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            ToolTipService.ToolTip="{x:Bind FullDateTime, Mode=OneWay}">
                    <TextBlock Margin="16,0,0,0"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="{x:Bind Date, Mode=OneWay}"
                               TextWrapping="NoWrap"
                               Visibility="{x:Bind IsToday, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <TextBlock Margin="16,0,0,0"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="{x:Bind Time, Mode=OneWay}"
                               TextWrapping="NoWrap" />
                </StackPanel>

                <Grid x:Name="CompactDateTimeInfo"
                      Grid.Column="4"
                      Margin="16,0,0,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      ToolTipService.ToolTip="{x:Bind FullDateTime, Mode=OneWay}"
                      Visibility="Collapsed">
                    <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="{x:Bind Time, Mode=OneWay}"
                               TextWrapping="NoWrap"
                               Visibility="{x:Bind IsToday, Mode=OneWay}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="{x:Bind Date, Mode=OneWay}"
                               TextWrapping="NoWrap"
                               Visibility="{x:Bind IsToday, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                </Grid>

            </Grid>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ModeStates">
                <VisualState x:Name="NameAddressMode">
                    <VisualState.StateTriggers>
                        <toolkit:IsEqualStateTrigger Value="{x:Bind Mode, Mode=OneWay}" To="{StaticResource NameAddressModeKey}" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NameAddressSubjectMode">
                    <VisualState.StateTriggers>
                        <toolkit:IsEqualStateTrigger Value="{x:Bind Mode, Mode=OneWay}" To="{StaticResource NameAddressSubjectModeKey}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MessageAddressBlock.Visibility" Value="Collapsed" />
                        <Setter Target="MessageSubjectBlock.Visibility" Value="Visible" />
                        <Setter Target="MessageSenderPresenter.Mode" Value="Normal" />
                        <Setter Target="MessageSenderTooltip.Mode" Value="Formatted" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <toolkit:ControlSizeTrigger MinWidth="{StaticResource CompactWidth}"
                                                    MaxWidth="{StaticResource NarrowWidth}"
                                                    TargetElement="{x:Bind ParentGrid}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="CompactDateTimeInfo.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Compact">
                    <VisualState.StateTriggers>
                        <toolkit:ControlSizeTrigger MinWidth="{StaticResource MiniWidth}"
                                                    MaxWidth="{StaticResource CompactWidth}"
                                                    TargetElement="{x:Bind ParentGrid}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SecurityInfo.Visibility" Value="Collapsed" />
                        <Setter Target="DateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="CompactDateTimeInfo.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Mini">
                    <VisualState.StateTriggers>
                        <toolkit:ControlSizeTrigger MinWidth="{StaticResource MicroWidth}"
                                                    MaxWidth="{StaticResource MiniWidth}"
                                                    TargetElement="{x:Bind ParentGrid}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SecurityInfo.Visibility" Value="Collapsed" />
                        <Setter Target="AttachmentInfo.Visibility" Value="Collapsed" />
                        <Setter Target="DateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="CompactDateTimeInfo.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Micro">
                    <VisualState.StateTriggers>
                        <toolkit:ControlSizeTrigger MinWidth="{StaticResource NanoWidth}"
                                                    MaxWidth="{StaticResource MicroWidth}"
                                                    TargetElement="{x:Bind ParentGrid}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SecurityInfo.Visibility" Value="Collapsed" />
                        <Setter Target="AttachmentInfo.Visibility" Value="Collapsed" />
                        <Setter Target="RecipientLabel.Visibility" Value="Collapsed" />
                        <Setter Target="RecipientControl.Visibility" Value="Collapsed" />
                        <Setter Target="DateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="CompactDateTimeInfo.Visibility" Value="Visible" />
                        <Setter Target="RecipientColumn.MinWidth" Value="0" />
                        <Setter Target="RecipientColumn.Width" Value="Auto" />
                        <Setter Target="InfoColumn.Width" Value="Auto" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Nano">
                    <VisualState.StateTriggers>
                        <toolkit:ControlSizeTrigger MaxWidth="{StaticResource NanoWidth}" TargetElement="{x:Bind ParentGrid}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RecipientLabel.Visibility" Value="Collapsed" />
                        <Setter Target="RecipientControl.Visibility" Value="Collapsed" />
                        <Setter Target="SecurityInfo.Visibility" Value="Collapsed" />
                        <Setter Target="AttachmentInfo.Visibility" Value="Collapsed" />
                        <Setter Target="DateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="CompactDateTimeInfo.Visibility" Value="Collapsed" />
                        <Setter Target="RecipientColumn.MinWidth" Value="0" />
                        <Setter Target="RecipientColumn.Width" Value="Auto" />
                        <Setter Target="InfoColumn.Width" Value="Auto" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
