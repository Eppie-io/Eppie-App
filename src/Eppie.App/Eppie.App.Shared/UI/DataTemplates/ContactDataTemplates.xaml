<ResourceDictionary x:Class="Eppie.App.UI.DataTemplates.ContactDataTemplates"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="using:Eppie.App.UI.Behaviors"
                    xmlns:controls="using:Eppie.App.UI.Controls"
                    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
                    xmlns:viewmodels="using:Tuvi.App.ViewModels">

    <DataTemplate x:Key="SuggestContactItemTemplate" x:DataType="viewmodels:ContactItem">
        <Grid Padding="2" BorderThickness="1">
            <controls:AddressPresenter HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Address="{x:Bind Email.Address, Mode=OneWay}"
                                       Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                       DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                       IsAddressValid="{x:Bind Email, Converter={StaticResource EmailValidityToBoolConverter}}"
                                       IsAvatarHighlighted="{x:Bind Email.IsDecentralized, Mode=OneWay}"
                                       IsSecure="{x:Bind Email.IsDecentralized, Mode=OneWay}">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddressPresenterTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </controls:AddressPresenter>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="TokenContactItemTemplate" x:DataType="viewmodels:ContactItem">
        <controls:AddressPresenter Margin="2"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Center"
                                   Address="{x:Bind Email.Address, Mode=OneWay}"
                                   Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                   DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                   IsAddressValid="{x:Bind Email, Converter={StaticResource EmailValidityToBoolConverter}}"
                                   IsAvatarHighlighted="{x:Bind Email.IsDecentralized, Mode=OneWay}"
                                   IsSecure="{x:Bind Email.IsDecentralized, Mode=OneWay}"
                                   Mode="Compact">
            <interactivity:Interaction.Behaviors>
                <behaviors:AddressPresenterTooltipBehavior Mode="Address" />
            </interactivity:Interaction.Behaviors>
        </controls:AddressPresenter>
    </DataTemplate>

</ResourceDictionary>
