<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:Eppie.App.UI.Converters"
                    xmlns:models="using:Eppie.App.Models"
                    xmlns:services="using:Eppie.App.Services">

    <services:FileOperationProvider x:Key="FileOperationProvider" />
    <services:ClipboardProvider x:Key="ClipboardProvider" />

    <converters:AttachmentConverter x:Key="AttachmentConverter" Parameter="{StaticResource FileOperationProvider}" />

    <models:BrandResource x:Key="Brand" />

    <x:Double x:Key="Int32MaxValue">2147483647</x:Double>

    <x:Boolean x:Key="FalseValue">False</x:Boolean>
    <x:Boolean x:Key="TrueValue">True</x:Boolean>

</ResourceDictionary>
