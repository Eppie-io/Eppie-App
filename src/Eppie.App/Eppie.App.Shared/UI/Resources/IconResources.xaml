<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Note: We can't use FontIconSource or SymbolIconSource as resources in UWP projects
        because icons may disappear or turn into emoji after a page reload.
        (same as https://github.com/microsoft/microsoft-ui-xaml/issues/7550)
    -->

    <x:Double x:Key="DefaultSymbolSize">16</x:Double>

    <x:String x:Key="BackGlyph">&#xE72B;</x:String>
    <x:String x:Key="MoreGlyph">&#xE712;</x:String>
    <x:String x:Key="DeleteGlyph">&#xE74D;</x:String>
    <x:String x:Key="AttachGlyph">&#xE723;</x:String>

    <x:String x:Key="MailReplyAllGlyph">&#xE8C2;</x:String>
    <x:String x:Key="MailForwardGlyph">&#xE89C;</x:String>
    <x:String x:Key="ReadGlyph">&#xE8C3;</x:String>
    <x:String x:Key="MailGlyph">&#xE715;</x:String>
    <x:String x:Key="MailFilledGlyph">&#xE8A8;</x:String>

    <x:String x:Key="Contact2Glyph">&#xE8D4;</x:String>

    <x:String x:Key="FlagGlyph">&#xE7C1;</x:String>
    <x:String x:Key="FlagFilledGlyph">&#xEB4B;</x:String>

    <x:String x:Key="RobotGlyph">&#xE99A;</x:String>
    <x:String x:Key="LockGlyph">&#xE72E;</x:String>

    <x:String x:Key="AddGlyph">&#xE710;</x:String>

    <StaticResource x:Key="MarkAsReadGlyph" ResourceKey="ReadGlyph" />
    <StaticResource x:Key="MarkAsUnreadGlyph" ResourceKey="MailGlyph" />
    <StaticResource x:Key="ReadStatusGlyph" ResourceKey="ReadGlyph" />
    <StaticResource x:Key="UnreadStatusGlyph" ResourceKey="MailGlyph" />

    <StaticResource x:Key="ActiveFlagGlyph" ResourceKey="FlagFilledGlyph" />
    <StaticResource x:Key="SetFlagGlyph" ResourceKey="FlagFilledGlyph" />
    <StaticResource x:Key="ClearFlagGlyph" ResourceKey="FlagGlyph" />

    <StaticResource x:Key="HiddenCopyGlyph" ResourceKey="Contact2Glyph" />
    <StaticResource x:Key="AIAgentGlyph" ResourceKey="RobotGlyph" />
    <StaticResource x:Key="SecurityGlyph" ResourceKey="LockGlyph" />

    <Style x:Key="DefaultFontIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="{StaticResource DefaultSymbolSize}" />
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
    </Style>

    <Style BasedOn="{StaticResource DefaultFontIconStyle}" TargetType="FontIcon" />

    <Style x:Key="DefaultViewboxStyle" TargetType="Viewbox">
        <Setter Property="Width" Value="{StaticResource DefaultSymbolSize}" />
        <Setter Property="Height" Value="{StaticResource DefaultSymbolSize}" />
    </Style>

    <Style BasedOn="{StaticResource DefaultViewboxStyle}" TargetType="Viewbox" />

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <StaticResource x:Key="InactiveFlagGlyph" ResourceKey="FlagFilledGlyph" />
            <StaticResource x:Key="UnreadFilledStatusGlyph" ResourceKey="MailFilledGlyph" />

            <StaticResource x:Key="InactiveFlagBrush" ResourceKey="TextFillColorDisabledBrush" />
            <StaticResource x:Key="UnreadBrush" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
            <StaticResource x:Key="UnreadFilledBrush" ResourceKey="TextFillColorPrimaryBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="InactiveFlagGlyph" ResourceKey="FlagGlyph" />
            <StaticResource x:Key="UnreadFilledStatusGlyph" ResourceKey="MailGlyph" />

            <StaticResource x:Key="InactiveFlagBrush" ResourceKey="SystemColorButtonTextColor" />
            <StaticResource x:Key="UnreadBrush" ResourceKey="SystemColorButtonTextColor" />
            <StaticResource x:Key="UnreadFilledBrush" ResourceKey="SystemColorButtonTextColor" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <StaticResource x:Key="InactiveFlagGlyph" ResourceKey="FlagFilledGlyph" />
            <StaticResource x:Key="UnreadFilledStatusGlyph" ResourceKey="MailFilledGlyph" />

            <StaticResource x:Key="InactiveFlagBrush" ResourceKey="TextFillColorDisabledBrush" />
            <StaticResource x:Key="UnreadBrush" ResourceKey="TextOnAccentFillColorPrimaryBrush" />
            <StaticResource x:Key="UnreadFilledBrush" ResourceKey="TextFillColorPrimaryBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
