<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <LinearGradientBrush x:Key="GradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0.0" Color="#80334A" />
                <GradientStop Offset="0.5" Color="#404040" />
                <GradientStop Offset="1.0" Color="#338080" />
            </LinearGradientBrush>
            <StaticResource x:Key="AvatarHighlightedBrush" ResourceKey="GradientBrush" />
            <StaticResource x:Key="P2PGradientBrush" ResourceKey="GradientBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="GradientBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AvatarHighlightedBrush" ResourceKey="GradientBrush" />
            <StaticResource x:Key="P2PGradientBrush" ResourceKey="GradientBrush" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <LinearGradientBrush x:Key="GradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0.0" Color="#FFD9EE" />
                <GradientStop Offset="0.5" Color="#FFFFFF" />
                <GradientStop Offset="1.0" Color="#D9FFFF" />
            </LinearGradientBrush>
            <StaticResource x:Key="AvatarHighlightedBrush" ResourceKey="GradientBrush" />
            <StaticResource x:Key="P2PGradientBrush" ResourceKey="GradientBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
