<Application x:Class="Eppie.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Eppie.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Load WinUI resources  -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Converters/ConvertersDictionary.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/ThemeResources.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/ThinButtonStyle.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/SimpleButtonStyle.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/SimpleToggleButtonStyle.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/PersonPictureStyle.xaml" />
                <ResourceDictionary Source="ms-appx:///Eppie.App.UI/Styles/TuviMailStyles.xaml" />

                <ResourceDictionary Source="ms-appx:///UI/Resources/EppieResources.xaml" />
                <ResourceDictionary Source="ms-appx:///UI/Resources/DummyResources.xaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
