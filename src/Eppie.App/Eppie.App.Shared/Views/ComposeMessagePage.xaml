<local:ComposeMessagePageBase x:Class="Eppie.App.Views.ComposeMessagePage"
                              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:behaviors="using:Eppie.App.UI.Behaviors"
                              xmlns:controls="using:Eppie.App.UI.Controls"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
                              xmlns:local="using:Eppie.App.Views"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                              xmlns:toolkit="using:CommunityToolkit.WinUI"
                              xmlns:triggers="using:Eppie.App.UI.Triggers"
                              xmlns:ui="using:CommunityToolkit.WinUI"
                              xmlns:uitools="using:Eppie.App.UI.Tools"
                              xmlns:viewmodels="using:Tuvi.App.ViewModels"
                              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                              mc:Ignorable="d">

    <local:ComposeMessagePageBase.DataContext>
        <viewmodels:ComposeMessagePageViewModel />
    </local:ComposeMessagePageBase.DataContext>

    <local:ComposeMessagePageBase.Resources>
        <x:Double x:Key="MainAreaMaxWidth">960</x:Double>
        <x:Double x:Key="SideAreaMinWidth">20</x:Double>

        <x:Double x:Key="SenderAddressBoxMinWidth">72</x:Double>
        <x:Double x:Key="SenderAddressBoxMaxWidth">232</x:Double>

        <x:Double x:Key="SendButtonMinWidth">112</x:Double>
        <x:Double x:Key="SendButtonMaxWidth">200</x:Double>
        <x:Double x:Key="SendButtonCompactWidth">32</x:Double>

        <x:Double x:Key="CommandButtonAreaMinWidth">40</x:Double>
        <x:Double x:Key="CommandsAreaMinWidth">80</x:Double>

        <x:Double x:Key="MessageEditorMinHeight">160</x:Double>

        <x:Double x:Key="ProgressRingSize">48</x:Double>
        <x:Double x:Key="AddressItemMaxWidth">500</x:Double>

        <x:Double x:Key="FooterMiniWidth">280</x:Double>
        <x:Double x:Key="FooterCompactWidth">460</x:Double>
        <x:Double x:Key="FooterNarrowWidth">600</x:Double>

        <Thickness x:Key="HorizontalMargin">0,0,12,0</Thickness>
        <Thickness x:Key="BlindCarbonCopyMargin">0,8,0,0</Thickness>

        <XamlUICommand x:Key="DraftAndBackUICommand"
                       x:Uid="DraftAndBackUICommand"
                       Command="{x:Bind ViewModel.GoBackCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Back}" />

        <XamlUICommand x:Key="MoreUICommand"
                       x:Uid="MoreUICommand"
                       IconSource="{ui:SymbolIconSource Symbol=More}" />

        <XamlUICommand x:Key="AttachUICommand"
                       x:Uid="AttachUICommand"
                       Command="{x:Bind ViewModel.AttachFilesCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Attach}" />

        <XamlUICommand x:Key="DeleteMessageUICommand"
                       x:Uid="DeleteMessageUICommand"
                       Command="{x:Bind ViewModel.DeleteMessageAndGoBackCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Delete}" />

        <XamlUICommand x:Key="SendMessageUICommand"
                       x:Uid="SendMessageUICommand"
                       Command="{x:Bind ViewModel.SendMessageAndGoBackCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Send}" />

        <DataTemplate x:Key="RemovableAttachmentItemTemplate" x:DataType="viewmodels:RemovableAttachment">
            <controls:AttachmentFileControl DeleteFileCommand="{x:Bind RemoveCommand}"
                                            DeleteFileCommandParameter="{x:Bind}"
                                            FileExtension="{x:Bind FileExtension, Mode=OneWay}"
                                            FileName="{x:Bind FileName, Mode=OneWay}"
                                            FileSize="{x:Bind FileSize, Mode=OneWay}"
                                            FileThumbnail="{x:Bind FileThumbnail, Mode=OneWay}"
                                            IsFileEmpty="{x:Bind IsEmpty, Mode=OneWay}"
                                            OpenFileCommand="{x:Bind OpenCommand}"
                                            OpenFileCommandParameter="{x:Bind Converter={StaticResource AttachmentConverter}}" />
        </DataTemplate>


        <DataTemplate x:Key="AddressComboBoxSelectedItemTemplate" x:DataType="viewmodels:AddressItem">
            <controls:AddressPresenter Address="{x:Bind Address, Mode=OneWay}"
                                       Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                       DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                       IsSecure="{x:Bind IsDecentralized, Mode=OneWay}"
                                       Mode="Compact" />
        </DataTemplate>

        <DataTemplate x:Key="AddressComboBoxItemTemplate" x:DataType="viewmodels:AddressItem">
            <controls:AddressPresenter MaxWidth="{StaticResource AddressItemMaxWidth}"
                                       Address="{x:Bind Address, Mode=OneWay}"
                                       Avatar="{x:Bind AvatarInfo, Mode=OneWay, Converter={StaticResource ImageInfoToBitmapConverter}}"
                                       DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                       IsSecure="{x:Bind IsDecentralized, Mode=OneWay}">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddressPresenterTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </controls:AddressPresenter>
        </DataTemplate>

        <uitools:ComboBoxDataTemplateSelector x:Key="ComboBoxDataTemplateSelector"
                                              ItemTemplate="{StaticResource AddressComboBoxItemTemplate}"
                                              SelectedTemplate="{StaticResource AddressComboBoxSelectedItemTemplate}" />

        <DataTemplate x:Key="FooterTemplate" x:DataType="viewmodels:ComposeMessagePageViewModel">
            <!--
                Note: VisualStateManager cannot be applied directly to a DataTemplate because
                DataTemplate elements are not Control subclasses, which are required for the VisualStateManager.
            -->
            <!--  ToDo: Place this code in a separate control and replace Binding with x:Bind in the VisualStateManager.  -->
            <UserControl>
                <Grid x:Name="ParentGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MaxWidth="{StaticResource SenderAddressBoxMaxWidth}" />
                            <ColumnDefinition Width="*" MinWidth="{StaticResource CommandsAreaMinWidth}" />
                        </Grid.ColumnDefinitions>

                        <ComboBox MinWidth="{StaticResource SenderAddressBoxMinWidth}"
                                  Margin="{StaticResource HorizontalMargin}"
                                  VerticalAlignment="Center"
                                  ItemTemplateSelector="{StaticResource ComboBoxDataTemplateSelector}"
                                  ItemsSource="{x:Bind SenderAddresses, Mode=OneWay}"
                                  SelectedIndex="{x:Bind SenderAddressIndex, Mode=TwoWay}"
                                  Style="{StaticResource AddressComboBoxStyle}"
                                  ToolTipService.ToolTip="{x:Bind local:ComposeMessagePage.GetSenderToolTip(Account), Mode=OneWay}" />

                        <Grid x:Name="Commands"
                              Grid.Column="1"
                              HorizontalAlignment="Left">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="{StaticResource CommandButtonAreaMinWidth}" />
                                <ColumnDefinition Width="*" MinWidth="{StaticResource CommandButtonAreaMinWidth}" />
                            </Grid.ColumnDefinitions>

                            <controls:CommandButton x:Name="AttachButton"
                                                    Grid.Column="0"
                                                    Margin="4,0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Command="{StaticResource AttachUICommand}"
                                                    CommandParameter="{StaticResource FileOperationProvider}">
                                <interactivity:Interaction.Behaviors>
                                    <behaviors:CommandButtonTooltipBehavior />
                                </interactivity:Interaction.Behaviors>
                            </controls:CommandButton>

                            <controls:CommandButton x:Name="DeleteMessageButton"
                                                    Grid.Column="1"
                                                    Margin="4,0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Command="{StaticResource DeleteMessageUICommand}" />
                        </Grid>
                    </Grid>

                    <controls:CommandButton x:Name="SendMessageButton"
                                            Grid.Column="2"
                                            MinWidth="{StaticResource SendButtonMinWidth}"
                                            MaxWidth="{StaticResource SendButtonMaxWidth}"
                                            Margin="4,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            ButtonBaseStyle="{StaticResource AccentButtonStyle}"
                                            Command="{StaticResource SendMessageUICommand}"
                                            Mode="TextOnly">
                        <interactivity:Interaction.Behaviors>
                            <behaviors:CommandButtonTooltipBehavior />
                        </interactivity:Interaction.Behaviors>
                    </controls:CommandButton>

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Narrow">
                                <VisualState.StateTriggers>
                                    <toolkit:ControlSizeTrigger MinWidth="{StaticResource FooterCompactWidth}"
                                                                MaxWidth="{StaticResource FooterNarrowWidth}"
                                                                TargetElement="{Binding ElementName=ParentGrid}" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="AttachButton.Mode" Value="IconOnly" />
                                    <Setter Target="DeleteMessageButton.Mode" Value="IconOnly" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Compact">
                                <VisualState.StateTriggers>
                                    <toolkit:ControlSizeTrigger MinWidth="{StaticResource FooterMiniWidth}"
                                                                MaxWidth="{StaticResource FooterCompactWidth}"
                                                                TargetElement="{Binding ElementName=ParentGrid}" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="AttachButton.Mode" Value="IconOnly" />
                                    <Setter Target="DeleteMessageButton.Mode" Value="IconOnly" />
                                    <Setter Target="SendMessageButton.Mode" Value="IconOnly" />
                                    <Setter Target="SendMessageButton.MinWidth" Value="{StaticResource SendButtonCompactWidth}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Mini">
                                <VisualState.StateTriggers>
                                    <toolkit:ControlSizeTrigger MaxWidth="{StaticResource FooterMiniWidth}" TargetElement="{Binding ElementName=ParentGrid}" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="AttachButton.Mode" Value="IconOnly" />
                                    <Setter Target="DeleteMessageButton.Mode" Value="IconOnly" />
                                    <Setter Target="SendMessageButton.Mode" Value="IconOnly" />
                                    <Setter Target="SendMessageButton.MinWidth" Value="{StaticResource SendButtonCompactWidth}" />
                                    <Setter Target="Commands.Visibility" Value="Collapsed" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Grid>
            </UserControl>
        </DataTemplate>
    </local:ComposeMessagePageBase.Resources>

    <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100*" MaxWidth="{StaticResource MainAreaMaxWidth}" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="ScrollArea"
                      Grid.Row="0"
                      Grid.RowSpan="3"
                      Grid.Column="2"
                      Grid.ColumnSpan="2"
                      Margin="0,0,-24,0"
                      Padding="0,76,24,24"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      ZoomMode="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100*" MaxWidth="{StaticResource MainAreaMaxWidth}" />
                    <ColumnDefinition Width="1*" MinWidth="{StaticResource SideAreaMinWidth}" />
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Orientation="Vertical">

                    <!--  Subject  -->
                    <controls:PromptTextInputControl x:Uid="MessageSubjectBox"
                                                     Margin="0,0,0,16"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Top"
                                                     Text="{x:Bind ViewModel.Subject, Mode=TwoWay}" />

                    <Grid Padding="24,12,24,20"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                          CornerRadius="{ThemeResource ControlCornerRadius}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" MinHeight="{StaticResource MessageEditorMinHeight}" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Receiver (To)  -->
                        <TextBlock x:Uid="MessageTo"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="{StaticResource HorizontalMargin}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center" />

                        <controls:EmailsInputControl x:Uid="MessageReceiverBox"
                                                     Grid.Row="0"
                                                     Grid.Column="1"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Contacts="{x:Bind ViewModel.Contacts, Mode=OneWay}"
                                                     ExtraCommand="{x:Bind ViewModel.ToggleHiddenCopyCommand, Mode=OneWay}"
                                                     IsExtraButtonVisible="True"
                                                     SelectedContacts="{x:Bind ViewModel.To, Mode=OneWay}"
                                                     UntokenizedContact="{x:Bind ViewModel.UntokenizedContactTo, Mode=TwoWay}">
                            <controls:EmailsInputControl.ExtraButtonContent>
                                <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <IconSourceElement IconSource="{ui:FontIconSource Glyph={StaticResource HiddenCopyGlyph}}" />
                                </Viewbox>
                            </controls:EmailsInputControl.ExtraButtonContent>
                        </controls:EmailsInputControl>

                        <Grid Grid.Row="1"
                              Grid.Column="0"
                              Margin="{StaticResource BlindCarbonCopyMargin}"
                              Visibility="{x:Bind ViewModel.IsHiddenCopyVisible, Mode=OneWay}">
                            <Viewbox Margin="{StaticResource HorizontalMargin}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center">
                                <IconSourceElement IconSource="{ui:FontIconSource Glyph={StaticResource HiddenCopyGlyph}}" />
                            </Viewbox>
                        </Grid>

                        <!--  Hidden copy (BCC)  -->
                        <controls:EmailsInputControl x:Uid="BlindCarbonCopyBox"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     Margin="{StaticResource BlindCarbonCopyMargin}"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     Contacts="{x:Bind ViewModel.Contacts, Mode=OneWay}"
                                                     IsExtraButtonVisible="False"
                                                     SelectedContacts="{x:Bind ViewModel.HiddenCopy, Mode=OneWay}"
                                                     UntokenizedContact="{x:Bind ViewModel.UntokenizedContactHiddenCopy, Mode=TwoWay}"
                                                     Visibility="{x:Bind ViewModel.IsHiddenCopyVisible, Mode=OneWay}" />

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Margin="0,28,0,0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              AllowDrop="True"
                              DragOver="OnDragOver"
                              Drop="OnDrop">

                            <controls:EditMessageControl x:Uid="EditMessageBox"
                                                         HorizontalAlignment="Stretch"
                                                         VerticalAlignment="Stretch"
                                                         AIAgentProcessedBody="{x:Bind ViewModel.MessageInfo.AIAgentProcessedBody, Mode=OneWay}"
                                                         Html="{x:Bind ViewModel.HtmlBody, Mode=TwoWay}"
                                                         Text="{x:Bind ViewModel.TextBody, Mode=TwoWay}"
                                                         Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                            <!--  UnoBug: Android doesn't have Visibility=Collapsed for ProgressRing.  -->
                            <Grid Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay}">
                                <ProgressRing Width="{StaticResource ProgressRingSize}"
                                              Height="{StaticResource ProgressRingSize}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsActive="True" />
                            </Grid>
                        </Grid>

                        <!--  Attachments  -->
                        <!--  Note: Background="Transparent" is used to allow drag and drop operations on the entire Border element  -->
                        <Border Grid.Row="3"
                                Grid.ColumnSpan="2"
                                AllowDrop="True"
                                Background="Transparent"
                                DragOver="OnDragOver"
                                Drop="OnDrop"
                                Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <controls:SimpleExpander x:Uid="AttachedFilesTitle"
                                                     Margin="0,24,0,0"
                                                     GlyphPosition="Left"
                                                     IsExpanded="True"
                                                     Visibility="{x:Bind ViewModel.HasAttachments, Mode=OneWay}">
                                <controls:AttachmentRepeaterControl Margin="0,16,0,0"
                                                                    VerticalAlignment="Top"
                                                                    ItemTemplate="{StaticResource RemovableAttachmentItemTemplate}"
                                                                    Items="{x:Bind ViewModel.Attachments, Mode=OneWay}" />
                            </controls:SimpleExpander>
                        </Border>

                        <ContentControl x:Name="Footer"
                                        Grid.Row="4"
                                        Grid.ColumnSpan="2"
                                        Margin="0,36,0,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Content="{x:Bind ViewModel}"
                                        ContentTemplate="{StaticResource FooterTemplate}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!--  Header  -->
        <!--  Save Draft and Back  -->
        <controls:CommandButton Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,24,8,20"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{StaticResource DraftAndBackUICommand}"
                                Mode="IconOnly" />

        <Grid Grid.Row="0"
              Grid.Column="2"
              Margin="0,24,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Title  -->
            <TextBlock x:Uid="ComposeEmailTitle"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="Medium" />

            <!--  More options  -->
            <controls:CommandButton Grid.Column="1"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource MoreUICommand}"
                                    Mode="IconOnly">
                <controls:CommandButton.Flyout>
                    <MenuFlyout>

                        <MenuFlyoutItem Command="{StaticResource AttachUICommand}" CommandParameter="{StaticResource FileOperationProvider}" />

                        <MenuFlyoutItem Command="{StaticResource DeleteMessageUICommand}" />

                        <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsExtraSettingsVisible, Mode=OneWay}" />

                        <MenuFlyoutSubItem x:Uid="SecurityMenuSection"
                                           Icon="{ui:FontIcon Glyph={StaticResource SecurityGlyph}}"
                                           Visibility="{x:Bind ViewModel.IsAdvancedSettingsVisible, Mode=OneWay}">
                            <MenuFlyoutSubItem.Items>
                                <ToggleMenuFlyoutItem x:Uid="MessageEncryptedMenuItem"
                                                      IsChecked="{x:Bind ViewModel.IsEncrypted, Mode=TwoWay}"
                                                      IsEnabled="{x:Bind ViewModel.IsChangeCryptographyEnabled, Mode=OneWay}" />

                                <ToggleMenuFlyoutItem x:Uid="MessageSignedMenuItem"
                                                      IsChecked="{x:Bind ViewModel.IsSigned, Mode=TwoWay}"
                                                      IsEnabled="{x:Bind ViewModel.IsChangeCryptographyEnabled, Mode=OneWay}" />
                                <MenuFlyoutItem x:Uid="PgpKeysMenuItem" Command="{x:Bind ViewModel.OpenAllPgpKeysCommand}" />
                            </MenuFlyoutSubItem.Items>
                        </MenuFlyoutSubItem>

                        <MenuFlyoutSubItem x:Name="AIAgentMenu"
                                           x:Uid="AIAgentMenuSection"
                                           Icon="{ui:FontIcon Glyph={StaticResource AIAgentGlyph}}"
                                           IsEnabled="{x:Bind ViewModel.IsLocalAIEnabled, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.IsLocalAIAvailable, Mode=OneWay}" />
                    </MenuFlyout>
                </controls:CommandButton.Flyout>
            </controls:CommandButton>
        </Grid>

        <!--  End Header  -->

        <Grid x:Name="AttachedFooter"
              Grid.Row="4"
              Grid.Column="2"
              Margin="0,0,0,24"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="Collapsed">
            <Border Padding="24,20,24,20"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                <ContentControl HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Content="{x:Bind ViewModel}"
                                ContentTemplate="{StaticResource FooterTemplate}" />
            </Border>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="ScrollVisibleState">
                    <VisualState.StateTriggers>
                        <triggers:VerticalScrollVisibilityTrigger TargetScrollViewer="{x:Bind ScrollArea}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="Footer.Opacity" Value="0" />
                        <Setter Target="AttachedFooter.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</local:ComposeMessagePageBase>
