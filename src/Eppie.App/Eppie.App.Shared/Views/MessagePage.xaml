<local:MessagePageBase x:Class="Eppie.App.Views.MessagePage"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:behaviors="using:Eppie.App.UI.Behaviors"
                       xmlns:controls="using:Eppie.App.UI.Controls"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:extensions="using:Eppie.App.UI.Extensions"
                       xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
                       xmlns:local="using:Eppie.App.Views"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                       xmlns:ui="using:CommunityToolkit.WinUI"
                       xmlns:viewmodels="using:Tuvi.App.ViewModels"
                       xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                       mc:Ignorable="d">

    <local:MessagePageBase.DataContext>
        <viewmodels:MessagePageViewModel />
    </local:MessagePageBase.DataContext>

    <local:MessagePageBase.Resources>
        <x:Double x:Key="MainAreaMaxWidth">960</x:Double>
        <x:Double x:Key="AvatarSize">44</x:Double>
        <x:Double x:Key="MessageViewMinHeight">120</x:Double>
        <x:Double x:Key="ProgressRingSize">48</x:Double>

        <DataTemplate x:Key="DownloadableAttachmentItemTemplate" x:DataType="viewmodels:DownloadableAttachment">
            <controls:AttachmentFileControl FileExtension="{x:Bind FileExtension, Mode=OneWay}"
                                            FileName="{x:Bind FileName, Mode=OneWay}"
                                            FileSize="{x:Bind FileSize, Mode=OneWay}"
                                            FileThumbnail="{x:Bind FileThumbnail, Mode=OneWay}"
                                            IsFileEmpty="{x:Bind IsEmpty, Mode=OneWay}"
                                            OpenFileCommand="{x:Bind OpenCommand}"
                                            OpenFileCommandParameter="{x:Bind Converter={StaticResource AttachmentConverter}}"
                                            SaveFileCommand="{x:Bind DownloadCommand}"
                                            SaveFileCommandParameter="{x:Bind Converter={StaticResource AttachmentConverter}}" />
        </DataTemplate>

        <XamlUICommand x:Key="BackUICommand"
                       x:Uid="BackUICommand"
                       Command="{x:Bind ViewModel.GoBackCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Back}" />

        <XamlUICommand x:Key="MoreUICommand"
                       x:Uid="MoreUICommand"
                       IconSource="{ui:SymbolIconSource Symbol=More}" />

        <XamlUICommand x:Key="ReplyAllUICommand"
                       x:Uid="ReplyAllUICommand"
                       Command="{x:Bind ViewModel.ReplyAllCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=MailReplyAll}" />

        <XamlUICommand x:Key="ForwardUICommand"
                       x:Uid="ForwardUICommand"
                       Command="{x:Bind ViewModel.ForwardCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=MailForward}" />

        <XamlUICommand x:Key="MarkMessageAsReadUICommand"
                       x:Uid="MarkMessageAsReadUICommand"
                       Command="{x:Bind ViewModel.MarkMessageAsReadCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource MarkAsReadGlyph}}" />

        <XamlUICommand x:Key="MarkMessageAsUnreadUICommand"
                       x:Uid="MarkMessageAsUnreadUICommand"
                       Command="{x:Bind ViewModel.MarkMessageAsUnreadCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource MarkAsUnreadGlyph}}" />

        <XamlUICommand x:Key="ReadStatusUICommand"
                       x:Uid="ReadStatusUICommand"
                       Command="{x:Bind ViewModel.MarkMessageAsUnreadCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource ReadStatusGlyph}}" />

        <!--  Todo: Add MailFilled back layer  -->
        <XamlUICommand x:Key="UnreadStatusUICommand"
                       x:Uid="UnreadStatusUICommand"
                       Command="{x:Bind ViewModel.MarkMessageAsReadCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource UnreadStatusGlyph}}" />

        <XamlUICommand x:Key="FlagMessageUICommand"
                       x:Uid="FlagMessageUICommand"
                       Command="{x:Bind ViewModel.FlagMessageCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource SetFlagGlyph}}" />

        <XamlUICommand x:Key="UnflagMessageUICommand"
                       x:Uid="UnflagMessageUICommand"
                       Command="{x:Bind ViewModel.UnflagMessageCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource ClearFlagGlyph}}" />

        <XamlUICommand x:Key="FlaggedStatusUICommand"
                       x:Uid="FlaggedStatusUICommand"
                       Command="{x:Bind ViewModel.UnflagMessageCommand}"
                       IconSource="{ui:FontIconSource Glyph={StaticResource ActiveFlagGlyph}}" />

        <XamlUICommand x:Key="UnflaggedStatusUICommand"
                       x:Uid="UnflaggedStatusUICommand"
                       Command="{x:Bind ViewModel.FlagMessageCommand}"
                       IconSource="{ui:FontIconSource Foreground={StaticResource InactiveFlagBrush},
                                                      Glyph={StaticResource InactiveFlagGlyph}}" />

        <XamlUICommand x:Key="DeleteMessageUICommand"
                       x:Uid="DeleteMessageUICommand"
                       Command="{x:Bind ViewModel.DeleteMessageAndGoBackCommand}"
                       IconSource="{ui:SymbolIconSource Symbol=Delete}" />

    </local:MessagePageBase.Resources>

    <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100*" MaxWidth="{StaticResource MainAreaMaxWidth}" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <!--  Back  -->
        <controls:CommandButton Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{StaticResource BackUICommand}"
                                IsCompact="True" />

        <Grid Grid.Row="1"
              Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Subject  -->
            <TextBlock HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="Medium"
                       IsTextSelectionEnabled="True"
                       Text="{x:Bind ViewModel.MessageInfo.MessageSubject, Mode=OneWay}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap">
                <interactivity:Interaction.Behaviors>
                    <behaviors:TextBlockTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </TextBlock>

            <!--  Several options  -->

            <controls:CommandButton Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource ReplyAllUICommand}">
                <interactivity:Interaction.Behaviors>
                    <behaviors:CommandButtonTooltipBehavior />
                </interactivity:Interaction.Behaviors>
            </controls:CommandButton>

            <controls:CommandButton Grid.Column="2"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource DeleteMessageUICommand}" />

            <!--  More options  -->
            <controls:CommandButton Grid.Column="3"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource MoreUICommand}"
                                    IsCompact="True">
                <controls:CommandButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Command="{StaticResource ReplyAllUICommand}" />
                        <MenuFlyoutItem Command="{StaticResource ForwardUICommand}" />
                        <MenuFlyoutItem Command="{StaticResource MarkMessageAsReadUICommand}" Visibility="{x:Bind ViewModel.MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <MenuFlyoutItem Command="{StaticResource MarkMessageAsUnreadUICommand}" Visibility="{x:Bind ViewModel.MessageInfo.IsMarkedAsRead, Mode=OneWay}" />
                        <MenuFlyoutItem Command="{StaticResource FlagMessageUICommand}" Visibility="{x:Bind ViewModel.MessageInfo.IsFlagged, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <MenuFlyoutItem Command="{StaticResource UnflagMessageUICommand}" Visibility="{x:Bind ViewModel.MessageInfo.IsFlagged, Mode=OneWay}" />
                        <MenuFlyoutItem Command="{StaticResource DeleteMessageUICommand}" ToolTipService.ToolTip="{x:Null}" />

                        <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsLocalAIAvailable, Mode=OneWay}" />

                        <MenuFlyoutSubItem x:Name="AIAgentMenu"
                                           x:Uid="AIAgentMenuSection"
                                           Icon="{ui:FontIcon Glyph={StaticResource AIAgentGlyph}}"
                                           IsEnabled="{x:Bind ViewModel.IsLocalAIEnabled, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.IsLocalAIAvailable, Mode=OneWay}" />
                    </MenuFlyout>
                </controls:CommandButton.Flyout>
            </controls:CommandButton>
        </Grid>

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,20,8,20"
                    Orientation="Vertical">

            <controls:CommandButton HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource ReadStatusUICommand}"
                                    IsCompact="True"
                                    Visibility="{x:Bind ViewModel.MessageInfo.IsMarkedAsRead, Mode=OneWay}" />

            <controls:CommandButton HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource UnreadStatusUICommand}"
                                    IsCompact="True"
                                    Visibility="{x:Bind ViewModel.MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

            <controls:CommandButton Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource UnflaggedStatusUICommand}"
                                    CommandParameter="{x:Bind ViewModel.MessageInfo, Mode=OneWay}"
                                    IsCompact="True"
                                    Visibility="{x:Bind ViewModel.MessageInfo.IsFlagged, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

            <controls:CommandButton Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{StaticResource FlaggedStatusUICommand}"
                                    CommandParameter="{x:Bind ViewModel.MessageInfo, Mode=OneWay}"
                                    IsCompact="True"
                                    Visibility="{x:Bind ViewModel.MessageInfo.IsFlagged, Mode=OneWay}" />
        </StackPanel>

        <Grid Grid.Row="3"
              Grid.Column="2"
              Padding="28,16,24,20"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              CornerRadius="{ThemeResource ControlCornerRadius}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="100*" MinHeight="{StaticResource MessageViewMinHeight}" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <muxc:PersonPicture Grid.Column="0"
                                Width="{StaticResource AvatarSize}"
                                Height="{StaticResource AvatarSize}"
                                Margin="0,4,16,0"
                                VerticalAlignment="Center"
                                DisplayName="{x:Bind ViewModel.MessageInfo.MessageSender, Mode=OneWay}" />

            <!--  Message Info  -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Sender  -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           IsTextSelectionEnabled="True"
                           Text="{x:Bind ViewModel.MessageInfo.SenderName, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextSelectionEnabled="True"
                           Text="{x:Bind ViewModel.MessageInfo.SenderEmail, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />

                <!--  ToDo: Add P2P and encryption labels.  -->

                <!--  Receiver  -->
                <!--  ToDo: Combine receivers and copy receivers  -->
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Margin="16,0,8,0"
                            Orientation="Horizontal"
                            Spacing="8">

                    <TextBlock x:Uid="MessageTo"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!--  ToDo: Create Control; Add tooltip; Add flyout with recipients  -->
                    <Border Height="32"
                            Padding="2,0,12,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Orientation="Horizontal">
                            <controls:AddressPresenter VerticalAlignment="Center"
                                                       DisplayName="{x:Bind ViewModel.MessageInfo.Account.DisplayEmail.Name, Mode=OneWay}"
                                                       Mode="Compact" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.MessageInfo.AdditionalRecipientCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                <Run Text="+" /><Run Text="{x:Bind ViewModel.MessageInfo.AdditionalRecipientCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           MinWidth="96"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Text="{x:Bind ViewModel.MessageInfo.DateBriefString, Mode=OneWay}"
                           TextAlignment="Right" />
            </Grid>

            <!--  Message  -->
            <Grid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Margin="0,24,0,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">

                <controls:MessageControl AIAgentProcessedBody="{x:Bind ViewModel.MessageInfo.AIAgentProcessedBody, Mode=OneWay}"
                                         ExternalContentDecider="{x:Bind ViewModel.ExternalContentDecider, Mode=OneWay}"
                                         HasHtmlBody="{x:Bind ViewModel.MessageInfo.HasHtmlBody, Mode=OneWay}"
                                         HtmlBody="{x:Bind ViewModel.MessageInfo.MessageHtmlBody, Mode=OneWay}"
                                         TextBody="{x:Bind ViewModel.MessageInfo.MessageTextBody, Mode=OneWay}"
                                         Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <!--  Wrapped to Grid because Android doesn't have Visibility=Collapsed for ProgressRing  -->
                <!--  ToDo: Check it on new Uno  -->
                <Grid Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay}">
                    <ProgressRing Width="{StaticResource ProgressRingSize}"
                                  Height="{StaticResource ProgressRingSize}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsActive="True" />
                </Grid>
            </Grid>

            <!--  Attachments  -->
            <StackPanel Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Orientation="Vertical"
                        Visibility="{x:Bind ViewModel.LoadingContent, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                <TextBlock x:Uid="AttachedFilesTitle"
                           Margin="0,24,0,0"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind ViewModel.MessageInfo.HasAttachments, Mode=OneWay}" />

                <ScrollViewer MinHeight="56"
                              MaxHeight="124"
                              Margin="0,16,0,0"
                              VerticalAlignment="Top"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              VerticalScrollMode="Auto"
                              Visibility="{x:Bind ViewModel.MessageInfo.HasAttachments, Mode=OneWay}"
                              ZoomMode="Disabled">
                    <controls:AttachmentRepeaterControl VerticalAlignment="Top"
                                                        ItemTemplate="{StaticResource DownloadableAttachmentItemTemplate}"
                                                        Items="{x:Bind ViewModel.Attachments, Mode=OneWay}" />
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </Grid>

</local:MessagePageBase>
