<UserControl x:Class="Eppie.App.Views.MessageItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <LinearGradientBrush x:Key="P2PGradientBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="#FFD9EE" />
                        <GradientStop Offset="0.5" Color="#FFFFFF" />
                        <GradientStop Offset="1.0" Color="#D9FFFF" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="P2PGradientBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="#FFD9EE" />
                        <GradientStop Offset="0.5" Color="#FFFFFF" />
                        <GradientStop Offset="1.0" Color="#D9FFFF" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="P2PGradientBrush" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="#80334A" />
                        <GradientStop Offset="0.5" Color="#404040" />
                        <GradientStop Offset="1.0" Color="#338080" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <XamlUICommand x:Key="DeleteUICommand"
                           x:Uid="/App.Resources/DeleteButton"
                           ExecuteRequested="OnDeleted">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Delete" />
                </XamlUICommand.IconSource>
                <!-- Todo: It doesn't work
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Delete" />
                </XamlUICommand.KeyboardAccelerators>
                -->
            </XamlUICommand>

            <XamlUICommand x:Key="MarkAsReadUICommand"
                           x:Uid="/App.Resources/MarkAsReadButton"
                           ExecuteRequested="OnMarkAsRead">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Read" />
                </XamlUICommand.IconSource>
                <!-- Todo: It doesn't work
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="R" Modifiers="Control" />
                </XamlUICommand.KeyboardAccelerators>
                -->
            </XamlUICommand>

            <XamlUICommand x:Key="MarkAsUnreadUICommand"
                           x:Uid="/App.Resources/MarkAsUnreadButton"
                           ExecuteRequested="OnMarkAsUnread">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Mail" />
                </XamlUICommand.IconSource>
                <!-- Todo: It doesn't work
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="U" Modifiers="Control" />
                </XamlUICommand.KeyboardAccelerators>
                -->
            </XamlUICommand>

            <XamlUICommand x:Key="FlagUICommand"
                           x:Uid="/App.Resources/SetFlagButton"
                           ExecuteRequested="OnFlagged">
                <XamlUICommand.IconSource>
                    <!--<SymbolIconSource Symbol="Flag" />-->
                    <FontIconSource FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xEB4B;" />
                </XamlUICommand.IconSource>
                <!-- Todo: It doesn't work
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F" Modifiers="Control, Shift" />
                </XamlUICommand.KeyboardAccelerators>
                -->
            </XamlUICommand>

            <XamlUICommand x:Key="UnflagUICommand"
                           x:Uid="/App.Resources/ClearFlagButton"
                           ExecuteRequested="OnUnflagged">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Flag" />
                </XamlUICommand.IconSource>
                <!-- Todo: It doesn't work
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="U" Modifiers="Control, Shift" />
                </XamlUICommand.KeyboardAccelerators>
                -->
            </XamlUICommand>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!--  TODO: Temporarily disable SwipeControl due to leak. Re-enable after fixing (TVM-344).  -->
        <!--<SwipeControl>
            <SwipeControl.LeftItems>
                <SwipeItems Mode="Execute">
                    <SwipeItem x:Uid="/App.Resources/ToggleReadSwipeItem"
                               Background="{ThemeResource SystemAccentColor}"
                               Invoked="OnLeftSwipeInvoked">
                        <SwipeItem.IconSource>
                            <SymbolIconSource Symbol="Read" />
                        </SwipeItem.IconSource>
                    </SwipeItem>
                </SwipeItems>
            </SwipeControl.LeftItems>
            <SwipeControl.RightItems>
                <SwipeItems Mode="Execute">
                    <SwipeItem x:Uid="/App.Resources/ToggleDeleteSwipeItem"
                               Background="{StaticResource WarningBackgroundBrush}"
                               Invoked="OnRightSwipeInvoked">
                        <SwipeItem.IconSource>
                            <SymbolIconSource Symbol="Delete" />
                        </SwipeItem.IconSource>
                    </SwipeItem>
                </SwipeItems>
            </SwipeControl.RightItems>-->

        <Grid Margin="0,2"
              Padding="16,6"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="24"
                  Height="24"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="14"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          Glyph="&#xE715;"
                          Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="14"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Glyph="&#xE8C3;"
                          Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay}" />
            </Grid>

            <Grid Grid.Row="1"
                  Width="24"
                  Height="24"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="14"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                          Glyph="&#xE81B;"
                          Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="14"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          Glyph="&#xEB4B;"
                          Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay}" />
            </Grid>

            <PersonPicture Grid.Column="1"
                           Width="40"
                           Height="40"
                           VerticalAlignment="Center"
                           DisplayName="{x:Bind MessageInfo.MessageSender, Mode=OneWay}" />

            <StackPanel Grid.Column="2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Style="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToAccentTextBlockStyleConverter}}"
                           Text="{x:Bind MessageInfo.SenderName, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind MessageInfo.SenderEmail, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,12,0"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{ThemeResource P2PGradientBrush}"
                        CornerRadius="8"
                        Visibility="{x:Bind MessageInfo.IsDecentralized, Mode=OneWay}">
                    <TextBlock x:Uid="P2PLabel"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               TextAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Style="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToAccentTextBlockStyleConverter}}"
                           Text="{x:Bind MessageInfo.MessageSubject, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
                <TextBlock Grid.Column="2"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind MessageInfo.PreviewText, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
            </Grid>

            <StackPanel x:Name="MetadataPanel"
                        Grid.Column="3"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">

                <Border Height="32"
                        Padding="4,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{x:Bind MessageInfo.HasAttachments, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Attach" />
                        <TextBlock VerticalAlignment="Center" Text="{x:Bind MessageInfo.AttachmentCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Uid="MessageTo"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Border Height="32"
                            Padding="4,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PersonPicture Width="24"
                                           Height="24"
                                           DisplayName="{x:Bind MessageInfo.Email.DisplayName, Mode=OneWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind MessageInfo.Email.Name, Mode=OneWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind MessageInfo.AdditionalRecipientCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                <Run Text="+" /><Run Text="{x:Bind MessageInfo.AdditionalRecipientCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock MinWidth="96"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Text="{x:Bind MessageInfo.DateBriefString, Mode=OneWay}"
                           TextAlignment="Right" />
            </StackPanel>
            <Grid.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Command="{StaticResource MarkAsReadUICommand}"
                                    CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                                    Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <MenuFlyoutItem Command="{StaticResource MarkAsUnreadUICommand}"
                                    CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                                    Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay}" />
                    <MenuFlyoutItem Command="{StaticResource FlagUICommand}"
                                    CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                                    Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <MenuFlyoutItem Command="{StaticResource UnflagUICommand}"
                                    CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                                    Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay}" />
                    <MenuFlyoutItem Command="{StaticResource DeleteUICommand}" CommandParameter="{x:Bind MessageInfo, Mode=OneWay}" />
                </MenuFlyout>
            </Grid.ContextFlyout>
        </Grid>
        <!--  TODO: Temporarily disable SwipeControl due to leak. Re-enable after fixing (TVM-344).  -->
        <!--</SwipeControl>-->

        <CommandBar x:Name="HoverCommandBar"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    DefaultLabelPosition="Collapsed"
                    OverflowButtonVisibility="Collapsed"
                    Visibility="Collapsed">
            <AppBarButton Command="{StaticResource MarkAsReadUICommand}"
                          CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                          Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
            <AppBarButton Command="{StaticResource MarkAsUnreadUICommand}"
                          CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                          Visibility="{x:Bind MessageInfo.IsMarkedAsRead, Mode=OneWay}" />
            <AppBarButton Command="{StaticResource FlagUICommand}"
                          CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                          Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
            <AppBarButton Command="{StaticResource UnflagUICommand}"
                          CommandParameter="{x:Bind MessageInfo, Mode=OneWay}"
                          Visibility="{x:Bind MessageInfo.IsFlagged, Mode=OneWay}" />
            <AppBarButton Command="{StaticResource DeleteUICommand}" CommandParameter="{x:Bind MessageInfo, Mode=OneWay}" />
        </CommandBar>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="HoveringStates">
                <VisualState x:Name="HoverButtonsHidden" />
                <VisualState x:Name="HoverButtonsShown">
                    <VisualState.Setters>
                        <Setter Target="HoverCommandBar.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
